{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"],
      "@components/*": ["components/*"],
      "@features/*": ["features/*"],
      "@lib/*": ["lib/*"],
      "@store/*": ["store/*"],
      "@types/*": ["types/*"],
      "@repo/db": ["../../../packages/db/src/index.ts"],
      "@repo/seo": ["../../../packages/seo/src/index.ts"],
      "@repo/sdk": ["../../../packages/sdk/src/index.ts"],
      "@repo/types": ["../../../packages/types/src/index.ts"],
      "@repo/utils": ["../../../packages/utils/src/index.ts"],
      "@repo/ui": ["../../../packages/ui/src/index.ts"],
      "@repo/ui/*": ["../../../packages/ui/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": ["jest", "node", "next-auth"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "../../packages/types/src/next-auth.d.ts"
  ],
  "exclude": ["node_modules"]
}
