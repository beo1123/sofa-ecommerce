{
  "name": "sofa-ecommerce",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "test": "echo \"No tests yet\"",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "dev": "pnpm --filter @repo/web dev",
    "dev:web": "pnpm --filter @repo/web dev",
    "dev:api": "pnpm --filter @repo/api dev",
    "dev:admin": "pnpm --filter @repo/admin dev",
    "dev:all": "concurrently \"pnpm dev:web\" \"pnpm dev:api\" \"pnpm dev:admin\"",
    "build": "pnpm --filter @repo/web build",
    "build:web": "pnpm --filter @repo/web build",
    "build:api": "pnpm --filter @repo/api build",
    "build:admin": "pnpm --filter @repo/admin build",
    "build:packages": "pnpm --filter @repo/types build && pnpm --filter @repo/utils build",
    "build:all": "pnpm build:packages && pnpm build:web && pnpm build:api && pnpm build:admin",
    "start": "pnpm --filter @repo/web start",
    "start:web": "pnpm --filter @repo/web start",
    "start:api": "pnpm --filter @repo/api start",
    "start:admin": "pnpm --filter @repo/admin start",
    "typecheck": "pnpm --filter @repo/web typecheck",
    "typecheck:web": "pnpm --filter @repo/web typecheck",
    "typecheck:api": "pnpm --filter @repo/api typecheck",
    "typecheck:admin": "pnpm --filter @repo/admin typecheck",
    "typecheck:all": "pnpm -r typecheck",
    "db:up": "docker compose -f docker-compose.postgres.yml up -d",
    "db:down": "docker compose -f docker-compose.postgres.yml down --remove-orphans",
    "db:reset": "docker compose -f docker-compose.postgres.yml down -v --remove-orphans",
    "db:logs": "docker compose -f docker-compose.postgres.yml logs -f postgres",
    "db:generate": "pnpm --filter @repo/db prisma:generate",
    "db:migrate": "pnpm --filter @repo/db prisma:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @repo/db prisma:migrate:deploy",
    "db:studio": "pnpm --filter @repo/db prisma:studio",
    "db:seed": "pnpm --filter @repo/db prisma:seed"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,html}": [
      "prettier --write"
    ]
  },
  "compilerOptions": {
    "types": [
      "jest",
      "node"
    ]
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.16.3",
    "@reduxjs/toolkit": "^2.9.1",
    "@tanstack/query-async-storage-persister": "^5.90.7",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tanstack/react-query-persist-client": "^5.90.7",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-text-align": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.22",
    "localforage": "^1.10.0",
    "lucide-react": "^0.544.0",
    "next": "^16.0.7",
    "next-auth": "^4.24.13",
    "pg": "^8.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.64.0",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/cli": "^4.1.14",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.19",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.8",
    "eslint": "^9.36.0",
    "eslint-config-next": "15.5.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.5",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prisma": "^6.16.3",
    "tailwindcss": "^4.1.14",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
