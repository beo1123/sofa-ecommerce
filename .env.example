# ──────────────────────────────
#  API & Next.js App
# ──────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<YOUR_RANDOM_64_CHAR_SECRET>
NEXT_PUBLIC_HEADER_LOGO=/images/logo-removebg-preview.png
NEXT_PUBLIC_PHONE_URL=0900000000
NEXT_PUBLIC_ZALO_URL=https://zalo.me/<YOUR_ZALO_ID>
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/<YOUR_PAGE>
# - Tạo NEXTAUTH_SECRET bằng: `openssl rand -base64 48`

# ──────────────────────────────
#  Database (PostgreSQL)
#  Chọn 1 trong 2 tùy môi trường
# ──────────────────────────────

# Option 1: Local + Docker (Postgres)
# DATABASE_URL="postgresql://postgres:<PASSWORD>@localhost:5433/sofa?schema=public"

# Option 2: Neon Cloud (luôn dùng SSL + channel_binding)
DATABASE_URL="postgresql://<NEON_USER>:<NEON_PASSWORD>@<NEON_HOST>/<NEON_DB>?sslmode=require&channel_binding=require"

# ──────────────────────────────
#  Cloudinary (Image CDN – Free tier)
#  Đăng ký tại: https://cloudinary.com
# ──────────────────────────────
# Cách 1 (khuyến nghị): copy 1 dòng CLOUDINARY_URL từ Dashboard
# CLOUDINARY_URL=cloudinary://<API_KEY>:<API_SECRET>@<CLOUD_NAME>

# Cách 2: tách riêng 3 biến
# CLOUDINARY_CLOUD_NAME=<YOUR_CLOUD_NAME>
# CLOUDINARY_API_KEY=<YOUR_API_KEY>
# CLOUDINARY_API_SECRET=<YOUR_API_SECRET>

# ──────────────────────────────
#  Seed admin user (optional)
#  Dùng cho: npm run prisma:seed:admin
# ──────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongPassword123!